path: /
duration: 30m
tag: rust

require:
  - cargo
  - clang
  - clevis-luks
  - cryptsetup-devel
  - libblkid-devel
  - just
  - python3-dbus
  - python3-dbus-client-gen
  - python3-dbus-python-client-gen
  - python3-psutil
  - python3-pyudev
  - rust
  - systemd-devel

environment:
  TANG_URL: localhost

/loop:
  test: just -f justfile test-clevis-loop
  summary: Run Rust tests that use loopbacked device framework for Clevis
